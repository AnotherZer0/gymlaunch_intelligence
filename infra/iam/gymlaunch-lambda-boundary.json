{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowLambdaRuntime",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents",
        "secretsmanager:GetSecretValue",
        "s3:PutObject",
        "s3:GetObject"
      ],
      "Resource": [
        "arn:aws:logs:*:*:*",
        "arn:aws:secretsmanager:*:*:secret:gymlaunch/*-*",
        "arn:aws:s3:::gymlaunch-*/*"
      ]
    },
    {
      "Sid": "AllowVPCNetworkInterface",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateNetworkInterface",
        "ec2:DescribeNetworkInterfaces",
        "ec2:DeleteNetworkInterface"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ExplicitDenyDangerous",
      "Effect": "Deny",
      "Action": [
        "iam:*",
        "rds:*",
        "s3:DeleteObject",
        "s3:DeleteBucket",
        "secretsmanager:DeleteSecret",
        "secretsmanager:UpdateSecret",
        "secretsmanager:RotateSecret",
        "secretsmanager:PutSecretValue"
      ],
      "Resource": "*"
    }
  ]
}
